# Wrangler CLI auth (for --remote commands like D1 migrations and deploy).
# Copy to .env and fill in values from https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
D1_DATABASE_ID=

# Worker runtime secret for local dev (also used by wrangler dev).
# SESSION_SECRET=
