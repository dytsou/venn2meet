{
  "name": "venn2meet",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "node scripts/wrangler-with-env.mjs deploy",
    "db:migrate": "node scripts/wrangler-with-env.mjs d1 migrations apply venn2meet --remote",
    "release": "pnpm db:migrate && pnpm deploy",
    "setup:env": "node scripts/setup-env.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "hono": "^4.9.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260602.1",
    "typescript": "^6.0.3",
    "vite": "^6.4.2",
    "vitest": "^4.1.7",
    "wrangler": "^4.20.5"
  }
}
