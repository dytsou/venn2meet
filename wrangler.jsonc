{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "venn2meet",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-30",
  "assets": {
    "directory": "./public",
    "run_worker_first": ["/api/*", "/e/*"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "venn2meet",
      "migrations_dir": "./migrations",
      "remote": true
    }
  ]
}
